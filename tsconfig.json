{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": false,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["api/**/*", "backend/src/**/*", "shared/**/*"]
}
